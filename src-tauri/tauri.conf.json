{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "M2 Lernbegleiter",
  "version": "0.1.0",
  "identifier": "com.m2lernbegleiter.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "widget",
        "title": "M2 Lernbegleiter",
        "url": "/",
        "width": 340,
        "height": 200,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": false,
        "visible": true
      },
      {
        "label": "dashboard",
        "title": "M2 Lernbegleiter - Dashboard",
        "url": "/dashboard",
        "width": 1100,
        "height": 750,
        "alwaysOnTop": false,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "M2 Lernbegleiter"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": {
        "db": "sqlite:m2_lernbegleiter.db"
      }
    },
    "notification": {
      "all": true
    }
  }
}
