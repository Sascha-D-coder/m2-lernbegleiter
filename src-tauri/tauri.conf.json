{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "M2 Lernbegleiter",
  "version": "0.1.0",
  "identifier": "com.m2lernbegleiter.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "widget",
        "title": "M2 Lernbegleiter",
        "url": "/",
        "width": 340,
        "height": 200,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": false,
        "visible": true
      },
      {
        "label": "dashboard",
        "title": "M2 Lernbegleiter - Dashboard",
        "url": "/dashboard",
        "width": 1100,
        "height": 750,
        "alwaysOnTop": false,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "M2 Lernbegleiter"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:m2_lernbegleiter.db"]
    },
    "notification": null,
    "updater": {
      "endpoints": [
        "https://github.com/saschadaul/m2-lernbegleiter/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFBMTI2Q0NDQzEzRjk3MzYKUldRMmx6L0J6R3dTcW9ucmNuVEo4aUl4Z2lRVE1ReUJXQXBVUVkrbk45Nk1pQUpTTllZZ2V6cUIK"
    },
    "shell": {
      "open": true
    }
  }
}
